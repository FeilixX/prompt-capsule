# Prompt Capsule config (config-over-code). Copy to .env and adjust per environment.
# Nothing secret here yet; real secrets stay in the server env / vault, never in git.

# Canonical share/base URL. Do NOT hardcode elsewhere.
PUBLIC_BASE_URL=https://n78.xyz

# Comma-separated hosts allowed to serve capsules.
ALLOWED_HOSTS=n78.xyz

# Route prefix for the raw text endpoint (/c/{slug}).
CAPSULE_ROUTE_PREFIX=/c

# Max capsule content size, in UTF-8 bytes.
MAX_CONTENT_BYTES=16384

# Default and hard-max TTL for anonymous capsules, in seconds (604800 = 7 days).
DEFAULT_TTL_SECONDS=604800
MAX_TTL_SECONDS=604800

# Random base62 slug length.
SLUG_LENGTH=8

# SQLite database file path.
DB_PATH=./data/capsules.db

# ---- Moderation (publish-then-review via DeepSeek) --------------------------
# Capsules publish immediately as `pending` (readable), then an out-of-band worker
# (scripts/moderate.ts) batches them to DeepSeek and flips approved/blocked.
# A `blocked` capsule reads as 404. enabled=false OR an empty key => worker no-ops.

MODERATION_ENABLED=false

# DeepSeek credentials. NEVER commit a real key — inject via server env / .env (gitignored).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Current fast tier. NB: deepseek-chat / deepseek-reasoner are deprecated 2026-07-24.
DEEPSEEK_MODEL=deepseek-v4-flash
# Outbound proxy for reaching api.deepseek.com. Empty = direct (aliyun/CN).
# Set to the Hiddify endpoint only for Mac-local testing, e.g. http://127.0.0.1:12334
DEEPSEEK_PROXY=

# How many capsules per DeepSeek call, clamped to 1..50 (token savings come from batching).
MODERATION_BATCH_SIZE=20
# Worker BASE loop period in seconds (clamped 1..86400; out-of-range falls back to 60). NB: on repeated DeepSeek failure the
# effective review window stretches via exponential backoff (up to ~600s) plus retry rounds,
# so the real "time until reviewed" ceiling is larger than this value.
MODERATION_INTERVAL_SEC=60
# Failed rounds before fail-open: after this many, a capsule is auto-approved so it never sticks in pending.
MODERATION_MAX_ATTEMPTS=3
# Per-request timeout (seconds) for one DeepSeek call — a hung request must not stall the worker.
MODERATION_TIMEOUT_SEC=30
